# Copia a .env y rellena (no subas .env al repositorio).

# --- Supabase: DATABASE_URL ---
# En el dashboard: Project Settings → Database → Connection string.
#
# Conexión DIRECTA (puerto 5432). A veces NO funciona desde redes solo IPv4:
#   host: db.<project_ref>.supabase.co
# Ejemplo de forma (sustituye TU_PASSWORD):
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.bakkcbqdcuktgmzztxcr.supabase.co:5432/postgres?sslmode=require
#
# Si ves "Not IPv4 compatible" o timeouts: usa Session mode / Session pooler.
# En el mismo apartado del dashboard elige "Session pooler" y copia la URI completa.
# Suele ser otro host (pooler) y puerto 6543, por ejemplo:
# DATABASE_URL=postgresql://postgres.bakkcbqdcuktgmzztxcr:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require
#
# Comprueba en el dashboard la cadena exacta; no uses URLs https:// del proyecto como DATABASE_URL.
DATABASE_URL=

# Opción B (recomendada si falla "password authentication failed"): variables sueltas.
# Si defines DB_HOST y DB_PASSWORD, tienen prioridad sobre DATABASE_URL.
# DB_HOST=db.<project_ref>.supabase.co
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=TU_PASSWORD
# DB_NAME=postgres
# DB_SSLMODE=require
# Timeout de conexión en segundos (default 3). Sube a 15 si hay "timeout expired".
# DB_CONNECT_TIMEOUT_SEC=15
#
# Si el host directo db.<ref>.supabase.co:5432 hace timeout (IPv6/red local):
# Dashboard → Database → Connection string → Session pooler → copia host y puerto 6543
# DB_HOST=aws-0-REGION.pooler.supabase.com
# DB_PORT=6543
# DB_USER=postgres.<project_ref>
#
# Vercel / serverless: usa SIEMPRE el Session pooler (6543) y sube el timeout:
# DB_CONNECT_TIMEOUT_SEC=15

# CORS: origen del front (en producción, tu dominio real).
# Varios orígenes separados por coma. En Vercel también se usan VERCEL_URL / VERCEL_BRANCH_URL.
FRONT_URL=http://localhost:3000
# Alias: CORS_ORIGINS (usa * para permitir todos; desactiva cookies/credentials en CORS)
# CORS_ORIGINS=https://restaurante.tabiapp.tech

# Opcional en Vercel (inyectadas automáticamente; no hace falta definirlas a mano):
# VERCEL_URL=bytte-backend.vercel.app
# VERCEL_BRANCH_URL=bytte-backend-git-main.vercel.app

# JWT (obligatorio en producción: cadena larga y aleatoria)
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres-seguros
# Alias compatible con otros servicios Tabi:
# SECRET_KEY=cambiar-en-produccion-minimo-32-caracteres-seguros
# Opcional: minutos de validez del access token (por defecto 480)
# JWT_EXPIRE_MINUTES=480

# Opcional: CHECK_DB_ON_IMPORT=1

# --- Supabase Storage (uploads onboarding) ---
# Bucket en Supabase: restaurant-documents (público)
# Políticas RLS: scripts/supabase_storage_setup.sql
SUPABASE_URL=https://bakkcbqdcuktgmzztxcr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Alias: SUPABASE_SERVICE_KEY=
STORAGE_BUCKET=restaurant-documents
# Alias opcional (base storage/v1; se deriva la URL pública del bucket):
# STORAGE_URL=https://bakkcbqdcuktgmzztxcr.supabase.co/storage/v1
# Opcional: si se omite, se deriva de SUPABASE_URL + STORAGE_BUCKET
# STORAGE_PUBLIC_URL=https://bakkcbqdcuktgmzztxcr.supabase.co/storage/v1/object/public/restaurant-documents
